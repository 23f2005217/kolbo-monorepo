# Ignore large directories
node_modules/
.turbo/
.tovedo/
*.log
.env
.env.*

# Ignore build outputs (will be rebuilt)
**/.next/
dist/
build/

# Ignore IDE
.idea/
.vscode/

# Ignore other apps when deploying maor-admin only
apps/hq/
apps/web/
apps/ads/
maor/

# Ignore git
.git/

# Ignore logs
logs/

# Ignore packages that will be installed
packages/*/node_modules/

# Ignore misc
.DS_Store
*.tsbuildinfo
.vercel/
