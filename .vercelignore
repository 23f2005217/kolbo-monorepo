# Ignore large directories
node_modules/
.turbo/
.tovedo/
*.log
.env
.env.*

# Ignore build outputs (will be rebuilt)
**/.next/
dist/
build/

# Ignore IDE
.idea/
.vscode/

# Note: Do NOT exclude apps/* here - it breaks monorepo workspace detection
# Vercel will only upload what's needed based on the turbo build graph
maor/

# Ignore git
.git/

# Ignore logs
logs/

# Ignore packages that will be installed
packages/*/node_modules/

# Ignore misc
.DS_Store
*.tsbuildinfo
.vercel/
