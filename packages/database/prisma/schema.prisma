generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  unpublished
  scheduled
  published
  archived
}

enum AdminRole {
  super_admin
  admin
}

enum AdsPlacement {
  pre_roll
  mid_roll
}

enum AdsMode {
  free_with_ads
  cheaper_with_ads
}

enum AssetStatus {
  preparing
  ready
  errored
}

enum CategoryType {
  video_row
  hero_banner
  large_text_block
  category_card_row
  divider
}

enum ContentType {
  video
  live_stream
}

enum EntitlementType {
  rental
  purchase
  subscription
}

enum ImageType {
  horizontal
  vertical
  hero
}

enum LiveSourceType {
  mux_rtmp
  browser
  zoom
}

enum OfferType {
  rental
  purchase
  subscription_access
  free_with_ads
  cheaper_with_ads
}

enum VideoAccessType {
  rental
  purchase
  subscription
}

// ==================== TABLES ====================

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  role          AdminRole @default(admin)
  displayName   String
  email         String    @unique
  passwordHash  String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  assignedVideos    Video[]
  assignedLiveStreams LiveStream[]
  assignedPlaylists Playlist[]

  @@map("admins")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  passwordHash String?
  name         String?
  dateOfBirth  DateTime?     @db.Date
  country      String?       @db.VarChar(2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  profile      Profile?
  transactions Transaction[]
}

model Creator {
  id          String   @id @default(uuid()) @db.Uuid
  displayName   String
  bio           String?
  payoutProfile Json?    @default("{}")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  videoCreators VideoCreator[]
  playlistCreators PlaylistCreator[]

  @@map("creators")
}

model Category {
  id          String       @id @default(uuid()) @db.Uuid
  type        CategoryType
  name        String
  description String?
  position    Int          @default(0)
  config      Json?        @default("{}")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  videos     Video[]
  playlists  Playlist[]
  liveStreams LiveStream[]
  playlistCategories PlaylistCategory[]

  @@map("categories")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model AdvertiserAccount {
  id           String   @id @default(uuid()) @db.Uuid
  companyName  String
  contactName  String
  email        String   @unique
  passwordHash String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns   AdCampaign[]
  creatives   AdCreative[]

  @@map("advertiser_accounts")
}

model AdCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  advertiserId    String    @db.Uuid
  name            String
  objective       String
  description     String?
  status          String    @default("draft")
  totalBudget     Int
  dailyBudget     Int?
  startDate       DateTime
  endDate         DateTime?
  frequencyCap    Int?
  frequencyPeriod String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  advertiser AdvertiserAccount      @relation(fields: [advertiserId], references: [id])
  targeting  AdCampaignTargeting?
  creatives  AdCreative[]
  analytics  AdCampaignAnalytics[]

  @@map("ad_campaigns")
}

model AdCampaignTargeting {
  id          String   @id @default(uuid()) @db.Uuid
  campaignId  String   @unique @db.Uuid
  regions     String[]
  zipCodes    String[]
  dmaCodes    String[]
  ageGroups   String[]
  genders     String[]
  channelIds  String[]
  categoryIds String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ad_campaign_targeting")
}

model AdCreative {
  id               String   @id @default(uuid()) @db.Uuid
  advertiserId     String   @db.Uuid
  campaignId       String?  @db.Uuid
  name             String
  storageBucket    String?
  storagePath      String?
  muxAssetId       String?  @unique
  muxPlaybackId    String?  @unique
  muxUploadId      String?
  durationSeconds  Int?
  width            Int?
  height           Int?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  advertiser AdvertiserAccount    @relation(fields: [advertiserId], references: [id])
  campaign   AdCampaign?          @relation(fields: [campaignId], references: [id])
  analytics  AdCreativeAnalytics[]

  @@map("ad_creatives")
}

model AdCampaignAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  campaignId  String   @db.Uuid
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  spend       Int      @default(0)
  ctr         Float    @default(0)
  cpm         Float    @default(0)
  cpc         Float    @default(0)
  createdAt   DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@map("ad_campaign_analytics")
}

model AdCreativeAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  creativeId  String   @db.Uuid
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  creative AdCreative @relation(fields: [creativeId], references: [id])

  @@unique([creativeId, date])
  @@map("ad_creative_analytics")
}

model AdInventory {
  id           String   @id @default(uuid()) @db.Uuid
  subsiteId    String   @unique @db.Uuid
  isAvailable  Boolean  @default(true)
  cpmCents     Int      @default(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subsite Subsite @relation(fields: [subsiteId], references: [id])

  @@map("ad_inventory")
}

model Filter {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  filterValues FilterValue[]

  @@map("filters")
}

model FilterValue {
  id       String  @id @default(uuid()) @db.Uuid
  filterId String  @db.Uuid
  label    String
  value    String
  position Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())

  // Relations
  filter       Filter          @relation(fields: [filterId], references: [id], onDelete: Cascade)
  videoFilters VideoFilterValue[]
  playlistFilters PlaylistFilterValue[]

  @@unique([filterId, value])
  @@map("filter_values")
}

model Subsite {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  thumbnailStorageBucket String?
  thumbnailStoragePath   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videos      Video[]
  adInventory AdInventory?

  @@map("subsites")
}

model Video {
  id                   String        @id @default(uuid()) @db.Uuid
  assignedAdminId      String?       @db.Uuid
  subsiteId            String?       @db.Uuid
  status               ContentStatus @default(unpublished)
  publishedAt          DateTime?
  publishScheduledAt   DateTime?
  title                String
  descriptionRich      String?
  shortDescription     String?
  slug                 String        @unique
  isFree               Boolean       @default(false)
  hasAds               Boolean       @default(false)
  adsMode              AdsMode?
  adsPlacement         AdsPlacement?
  midRollIntervalMinutes Int?        @default(10)
  adTagUrl             String?
  categoryId           String?       @db.Uuid
  trailerVideoId       String?       @db.Uuid
  trailerForceFree     Boolean       @default(false)
  seoKeywords          String[]
  seoTitle             String?
  seoDescription       String?
  minimumAge           Int?              @default(0)
  maxSimultaneousStreams Int?            @default(0)
  createdBy            String?       @db.Uuid
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  // Relations
  assignedAdmin Admin? @relation(fields: [assignedAdminId], references: [id])
  subsite       Subsite? @relation(fields: [subsiteId], references: [id])
  category      Category? @relation(fields: [categoryId], references: [id])
  assets        VideoAsset[]
  adMarkers     VideoAdMarker[]
  creators      VideoCreator[]
  offers        VideoOffer[]
  geoBlocks     VideoGeoBlock[]
  images        VideoImage[]
  subtitles     Subtitle[]
  searchTags    VideoSearchTag[]
  filterValues  VideoFilterValue[]
  artistVideos  ArtistVideo[]
  bundles       BundleVideo[]
  subscriptionPlans VideoSubscriptionPlan[]
  videoAccess   VideoAccess[]

  @@map("videos")
}

model VideoAsset {
  id String @id @default(uuid()) @db.Uuid
  videoId String @db.Uuid
  muxAssetId String @unique
  muxPlaybackId String? @unique
  muxPublicPlaybackId String?
  playbackPolicy String? @db.VarChar(10)
  muxUploadId String?
  status AssetStatus @default(preparing)
  durationSeconds Int?
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_assets")
}

model VideoAdMarker {
  id               String   @id @default(uuid()) @db.Uuid
  videoId          String   @db.Uuid
  timestampSeconds Int
  createdAt        DateTime @default(now())

  // Relations
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_ad_markers")
}

model VideoCreator {
  id              String   @id @default(uuid()) @db.Uuid
  videoId         String   @db.Uuid
  creatorId       String   @db.Uuid
  revenueShareBps Int      @default(0) // Basis points (10000 = 100%)
  createdAt       DateTime @default(now())

  // Relations
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([videoId, creatorId])
  @@map("video_creators")
}

model VideoOffer {
  id                     String    @id @default(uuid()) @db.Uuid
  videoId                String    @db.Uuid
  offerType              OfferType
  currency               String    @default("usd")
  amountCents            Int
  pricePerDeviceCents    Int       @default(0)
  rentalDurationDays     Int?
  maxSimultaneousStreams Int?
  tierLabel              String?
  stripeProductId        String?
  stripePriceId          String?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_offers")
}

model VideoGeoBlock {
  id          String   @id @default(uuid()) @db.Uuid
  videoId     String   @db.Uuid
  countryCode String   @db.VarChar(2) // ISO alpha-2
  createdAt   DateTime @default(now())

  // Relations
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, countryCode])
  @@map("video_geo_blocks")
}

model VideoImage {
  id            String   @id @default(uuid()) @db.Uuid
  videoId       String   @db.Uuid
  imageType     ImageType
  storageBucket String
  storagePath   String
  createdAt     DateTime @default(now())

  // Relations
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, imageType])
  @@map("video_images")
}

model Subtitle {
  id            String   @id @default(uuid()) @db.Uuid
  videoId       String   @db.Uuid
  languageCode  String   @db.VarChar(2) // ISO 639-1
  storageBucket String
  storagePath   String
  muxTrackId    String?
  label         String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Relations
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, languageCode])
  @@map("subtitles")
}

model SearchTag {
  id          String   @id @default(uuid()) @db.Uuid
  tag         String   @unique
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  videoTags VideoSearchTag[]

  @@map("search_tags")
}

model VideoSearchTag {
  id          String   @id @default(uuid()) @db.Uuid
  videoId     String   @db.Uuid
  searchTagId String   @db.Uuid
  createdAt   DateTime @default(now())

  // Relations
  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  searchTag SearchTag @relation(fields: [searchTagId], references: [id], onDelete: Cascade)

  @@unique([videoId, searchTagId])
  @@map("video_search_tags")
}

model VideoFilterValue {
  id             String   @id @default(uuid()) @db.Uuid
  videoId        String   @db.Uuid
  filterValueId  String   @db.Uuid
  createdAt      DateTime @default(now())

  // Relations
  video       Video       @relation(fields: [videoId], references: [id], onDelete: Cascade)
  filterValue FilterValue @relation(fields: [filterValueId], references: [id], onDelete: Cascade)

  @@unique([videoId, filterValueId])
  @@map("video_filter_values")
}

model LiveStream {
  id                     String          @id @default(uuid()) @db.Uuid
  assignedAdminId        String?         @db.Uuid
  status                 ContentStatus   @default(unpublished)
  title                  String
  descriptionRich        String?
  shortDescription       String?
  isFree                 Boolean         @default(false)
  preregEnabled          Boolean         @default(false)
  scheduledStartAt       DateTime?
  chatEnabled            Boolean         @default(true)
  remindersEnabled       Boolean         @default(true)
  donationsEnabled       Boolean         @default(false)
  rewindEnabled          Boolean         @default(true)
  sourceType             LiveSourceType?
  muxLiveStreamId        String?
  muxStreamKey           String?
  muxRtmpUrl             String?
  muxPlaybackId          String?
  srtPassphrase          String?
  zoomUrl                String?
  thumbnailStorageBucket String?
  thumbnailStoragePath   String?
  categoryId             String?         @db.Uuid
  createdBy              String?         @db.Uuid
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?

  // Relations
  assignedAdmin Admin? @relation(fields: [assignedAdminId], references: [id])
  category      Category? @relation(fields: [categoryId], references: [id])

  @@map("live_streams")
}

model SubscriptionPlan {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  stripeProductId String?  @unique
  stripePriceId   String?  @unique
  priceAmount     Int?     // Price in cents
  priceInterval   String?  @default("month") // month, year, week, day
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  videos          VideoSubscriptionPlan[]

  @@map("subscription_plans")
}

model VideoSubscriptionPlan {
  id                 String   @id @default(uuid()) @db.Uuid
  videoId            String   @db.Uuid
  subscriptionPlanId String   @db.Uuid
  createdAt          DateTime @default(now())

  // Relations
  video            Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)

  @@unique([videoId, subscriptionPlanId])
  @@map("video_subscription_plans")
}

model Entitlement {
  id                      String           @id @default(uuid()) @db.Uuid
  userId                  String           @db.Uuid
  contentType             ContentType
  contentId               String           @db.Uuid
  entitlementType         EntitlementType
  startsAt                DateTime         @default(now())
  expiresAt               DateTime?
  maxSimultaneousStreams  Int?             @default(1)
  stripeCustomerId        String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeSubscriptionId    String?
  stripePriceId           String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@unique([userId, contentType, contentId, entitlementType])
  @@map("entitlements")
}

model Playlist {
  id                     String        @id @default(uuid()) @db.Uuid
  assignedAdminId        String?       @db.Uuid
  title                  String
  descriptionRich        String?
  shortDescription       String?
  categoryId             String?       @db.Uuid
  trailerVideoId         String?       @db.Uuid
  isFree                 Boolean       @default(false)
  thumbnailStorageBucket String?
  thumbnailStoragePath   String?
  status                 ContentStatus @default(unpublished)
  publishScheduledAt     DateTime?
  position               Int           @default(0)
  createdBy              String?       @db.Uuid
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?

  // Relations
  assignedAdmin Admin?    @relation(fields: [assignedAdminId], references: [id])
  category      Category? @relation(fields: [categoryId], references: [id])
  items         PlaylistItem[]
  creators      PlaylistCreator[]
  offers        PlaylistOffer[]
  filterValues  PlaylistFilterValue[]
  categories    PlaylistCategory[]

  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(uuid()) @db.Uuid
  playlistId String   @db.Uuid
  videoId    String   @db.Uuid
  position   Int      @default(0)
  dripDays   Int?     @default(0)
  createdAt  DateTime @default(now())

  // Relations
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, videoId])
  @@map("playlist_items")
}

model PlaylistCreator {
  id              String   @id @default(uuid()) @db.Uuid
  playlistId      String   @db.Uuid
  creatorId       String   @db.Uuid
  revenueShareBps Int      @default(0)
  createdAt       DateTime @default(now())

  // Relations
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  creator  Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([playlistId, creatorId])
  @@map("playlist_creators")
}

model PlaylistOffer {
  id                     String    @id @default(uuid()) @db.Uuid
  playlistId             String    @db.Uuid
  offerType              OfferType
  currency               String    @default("usd")
  amountCents            Int
  rentalDurationDays     Int?
  maxSimultaneousStreams Int?
  tierLabel              String?
  stripeProductId        String?
  stripePriceId          String?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@map("playlist_offers")
}

model PlaylistFilterValue {
  id             String   @id @default(uuid()) @db.Uuid
  playlistId     String   @db.Uuid
  filterValueId  String   @db.Uuid
  createdAt      DateTime @default(now())

  // Relations
  playlist    Playlist    @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  filterValue FilterValue @relation(fields: [filterValueId], references: [id], onDelete: Cascade)

  @@unique([playlistId, filterValueId])
  @@map("playlist_filter_values")
}

model PlaylistCategory {
  id         String   @id @default(uuid()) @db.Uuid
  playlistId String   @db.Uuid
  categoryId String   @db.Uuid
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  // Relations
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([playlistId, categoryId])
  @@map("playlist_categories")
}

model StripeCustomer {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("stripe_customers")
}

model StripeEvent {
  id              String    @id @default(uuid()) @db.Uuid
  stripeEventId   String    @unique
  type            String
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  processingError String?

  @@map("stripe_events")
}

// ==================== MARKETING TABLES ====================

model PushNotification {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  message     String
  targetAudience String @default("all")
  scheduledAt DateTime?
  sentAt      DateTime?
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("push_notifications")
}

model Coupon {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique
  discountType    String    @default("percentage")
  discountValue   Int       // percentage (0-100) or fixed amount in cents
  appliesTo       String    @default("all")
  expiresAt       DateTime?
  usageLimit      Int?
  usageCount      Int       @default(0)
  perUserLimit    Int?
  allowCurrentSubscribers Boolean @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("coupons")
}

model UpsellOffer {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  trigger     String    // e.g., "pre_renewal", "upgrade"
  discount    Int       // percentage
  imageUrl    String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("upsell_offers")
}

// ==================== REVSHARE TABLES ====================

model Artist {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  email         String    @unique
  bio           String?
  imageUrl      String?
  payoutEmail   String?
  taxInfo       Json?
  totalStreams  Int       @default(0)
  totalRevenue  Int       @default(0) // in cents
  subscriptionSplit Int   @default(0) // percentage (0-100)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  agreements    RevShareAgreement[]
  videos        ArtistVideo[]

  @@map("artists")
}

model ArtistVideo {
  id            String    @id @default(uuid()) @db.Uuid
  artistId      String    @db.Uuid
  videoId       String    @db.Uuid
  revenueShareBps Int     @default(0) // basis points (10000 = 100%)
  createdAt     DateTime  @default(now())

  // Relations
  artist        Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  video         Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([artistId, videoId])
  @@map("artist_videos")
}

model RevShareAgreement {
  id              String    @id @default(uuid()) @db.Uuid
  artistId        String    @db.Uuid
  agreementType   String    @default("non_exclusive") // exclusive, non_exclusive
  durationMonths  Int       @default(12)
  revenueSharePercent Int   @default(50)
  listingFee      Int       @default(0) // in cents
  contractUrl     String?
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  artist          Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@map("revshare_agreements")
}

// ==================== CALENDAR TABLES ====================

model CalendarEvent {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  description String?
  eventType   String    @default("video") // video, live, promotion
  scheduledAt DateTime
  status      String    @default("scheduled") // scheduled, draft, completed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("calendar_events")
}

// ==================== TRANSACTION/SALES TABLES ====================

model Transaction {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  amount      Int       // in cents
  currency    String    @default("usd")
  status      String    @default("completed") // completed, pending, refunded, failed
  productType String    @default("subscription") // subscription, rental, purchase
  productName String?
  stripePaymentIntentId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Bundle {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Int?     // in cents
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videos      BundleVideo[]

  @@map("bundles")
}

model BundleVideo {
  id        String @id @default(uuid()) @db.Uuid
  bundleId  String @db.Uuid
  videoId   String @db.Uuid
  createdAt DateTime @default(now())

  bundle    Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  video     Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([bundleId, videoId])
  @@map("bundle_videos")
}

model Profile {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  maxDevices    Int       @default(5)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  playbackSessions PlaybackSession[]
  videoAccess      VideoAccess[]

  @@map("profiles")
}

model PlaybackSession {
  id            String    @id @default(uuid()) @db.Uuid
  profileId     String    @db.Uuid
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  deviceId      String
  deviceName    String?
  deviceType    String?
  
  videoId       String?   @db.Uuid
  muxPlaybackId String?
  
  lastActive    DateTime  @default(now())
  ipAddress     String?
  countryCode   String?   @db.VarChar(2)
  
  createdAt     DateTime  @default(now())

  @@index([profileId, lastActive])
  @@index([deviceId])
  @@map("playback_sessions")
}

model VideoAccess {
  id            String    @id @default(uuid()) @db.Uuid
  profileId     String    @db.Uuid
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  videoId       String    @db.Uuid
  video         Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  accessType    VideoAccessType
  
  expiresAt     DateTime?
  maxViewers    Int?
  
  entitlementId String?   @db.Uuid
  stripePaymentIntentId String?
  
  allowedCountries String[] @default([])
  blockedCountries String[] @default([])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([profileId, videoId, accessType])
  @@index([profileId])
  @@index([videoId])
  @@map("video_access")
}

