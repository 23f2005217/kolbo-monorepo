{
  "name": "kolbo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:hq": "turbo run dev --filter=@kolbo/hq",
    "dev:ads": "turbo run dev --filter=@kolbo/ads",
    "dev:web": "turbo run dev --filter=@kolbo/web",
    "dev:maor": "turbo run dev --filter=@kolbo/maor-admin",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@kolbo/database",
    "db:migrate": "turbo run db:migrate --filter=@kolbo/database",
    "db:push": "turbo run db:push --filter=@kolbo/database",
    "db:studio": "turbo run db:studio --filter=@kolbo/database"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
