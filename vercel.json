{
  "version": 2,
  "builds": [
    {
      "src": "apps/maor-admin/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/maor-admin/$1"
    }
  ],
  "installCommand": "npm install",
  "buildCommand": "cd apps/maor-admin && npm run build",
  "outputDirectory": "apps/maor-admin/.next"
}
